<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bộ Sưu Tập Sách – Thư Viện UCC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Lato:wght@400;700&display=swap"
        rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css"
        rel="stylesheet" />
    <link rel="stylesheet" href="/css/app.css" />
</head>

<body>
    <div class="container" style="max-width:1100px; padding: 20px 16px;">
        <div class="hero-card d-flex flex-wrap justify-content-between align-items-center gap-4 mb-4">
            <div>
                <div class="d-flex gap-3">
                    <div class="hero-logo-box">
                        <i class="bi bi-building-fill-check"></i>
                    </div>
                    <div>
                        <h1 class="hero-title">Bộ Sưu Tập Sách</h1>
                        <p class="hero-subtitle"><i class="bi bi-stars me-1"></i>Khám phá cuốn sách hay tiếp theo của
                            bạn</p>
                    </div>
                </div>
                <p class="hero-desc">
                    Hãy duyệt qua bộ sưu tập tài nguyên học thuật toàn diện của chúng tôi <br />
                    Tìm kiếm sách, kiểm tra tình trạng còn hay hết và thêm sách vào giỏ mượn một cách dễ dàng
                </p>
            </div>
            <button class="btn-sign-in">
                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập để mượn sách
            </button>
        </div>

        <div class="search-panel mb-4">
            <div class="d-flex gap-3 mb-1">
                <div class="search-icon-box"><i class="bi bi-search"></i></div>
                <div>
                    <h2 class="panel-title">Tìm Kiếm &amp; Khám Phá</h2>
                    <p class="panel-sub">Tìm chính xác những gì bạn cần với các công cụ tìm kiếm nâng cao của chúng tôi
                    </p>
                </div>
            </div>
            <form class="d-flex flex-wrap gap-3 align-items-center mt-3" action="/" method="get">
                <div class="search-wrap">
                    <i class="bi bi-search"></i>
                    <input class="search-input" type="text" name="searchbook"
                        placeholder="Tìm theo tên sách, tác giả, ISBN, Số đăng ký..." />
                </div>
                <select class="filter-select" id="categorySelect" name="category" onchange="this.form.submit()">
                    <option value="">Tất Cả Danh Mục</option>
                    {{#each categories}}
                    <option value="{{this._id}}">{{this.name}}</option>
                    {{/each}}
                </select>
                <select class="filter-select" id="statusSelect" name="status" onchange="this.form.submit()">
                    <option value="">Tất Cả Trạng Thái</option>
                    <option value="avaiable">Còn Sẵn</option>
                    <option value="borrow">Đang Mượn</option>
                </select>
            </form>
        </div>

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div class="d-flex align-items-center gap-3">
                <div class="results-icon-box"><i class="bi bi-book-half"></i></div>
                <div>
                    <p class="results-title">Tìm Thấy {{books.length}} Cuốn Sách</p>
                    <p class="results-sub">Tổng bộ sưu tập: {{countDocuments}} cuốn sách</p>
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <span class="stat-chip avail">Sẵn Có: {{availableQuantityTotal}}</span>
                <span class="stat-chip total">Tổng Số Bản Sao: {{totalCopies}}</span>
            </div>
        </div>

        {{#if books}}
        <div class="books-grid mb-4">
            {{#each books}}
            <div class="book-card" data-title="{{this.title}}" data-author="{{this.author}}" data-image="{{this.image}}"
                data-accession-number="{{this.accessionNumber}}" data-category="{{this.categoryId.name}}"
                data-isbn="{{this.isbn}}" data-total-quantity="{{this.totalQuantity}}">
                <div class="book-img-wrap">
                    <img src="{{this.image}}" alt="{{this.title}}" />
                    {{#if availableQuantity}}
                    <span class="badge-copies">còn {{this.availableQuantity}}</span>
                    <span class="badge-status available">còn sẵn</span>
                    {{else}}
                    <span class="badge-status borrowed">đã hết</span>
                    {{/if}}
                </div>
                <div class="book-info">
                    <p class="book-title">{{this.title}}</p>
                    <p class="book-author">bởi {{this.author}}</p>
                    <span class="book-cat cat-cs">{{this.categoryId.name}}</span>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        <div class="empty-card">
            <div class="empty-icon-wrap">
                <i class="bi bi-book-half"></i>
            </div>
            <p class="empty-title">Không tìm thấy sách nào</p>
            <p class="empty-sub">Hãy thử điều chỉnh tiêu chí tìm kiếm của bạn hoặc duyệt qua tất cả các danh mục.
            </p>
        </div>
        {{/if}}

        <div class="cta-section mb-4">
            <div class="cta-icon-box">
                <i class="bi bi-stars"></i>
            </div>
            <h2 class="cta-title">Sẵn sàng để bắt đầu đọc?</h2>
            <p class="cta-desc">
                Đăng nhập bằng thông tin tài khoản sinh viên của bạn để thêm sách vào giỏ hàng và tạo mã QR phiếu
                mượn
                Truy cập hàng ngàn tài nguyên học thuật ngay lập tức
            </p>
            <button class="btn-get-started">
                <i class="bi bi-box-arrow-in-right"></i> Bắt Đầu Ngay
            </button>
        </div>

        <footer>
            <div class="footer-brand">
                <span style="font-size:1.4rem;">🏫</span>
                <span style="font-size:1.3rem;">📖</span>
                Thư Viện UCC
            </div>
            <p class="footer-vision">
                Tầm nhìn của chúng tôi là tạo ra không gian học tập hiện đại, nơi kiến thức, công nghệ và cộng đồng
                hội
                tụ
            </p>
            <p class="footer-vision2">Chúng tôi hỗ trợ sinh viên và giảng viên đạt được thành tích học thuật xuất
                sắc
            </p>
            <hr class="footer-divider" />
            <p class="footer-copy">© {{currentYear}} Hệ Thống Quản Lý Thư Viện UCC. Bảo lưu mọi quyền</p>
            <div class="footer-links">
                <a href="#">Quyền Riêng Tư</a>
                <a href="#">Điều Khoản</a>
                <a href="#">Khả năng tiếp cận</a>
            </div>
        </footer>
    </div>

    <dialog id="bookDialog">
        <button id="closeDialogBtn" class="btn-close-custom">
            <i class="bi bi-x"></i>
        </button>

        <h2 class="dialog-title">Introduction to Computer Science</h2>
        <span>bởi </span><span class="dialog-subtitle">John Smith</span>

        <div class="book-image-container">
            <img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&q=80&w=400&h=500"
                alt="Book Cover" class="book-image">
        </div>

        <div class="row gy-4 mb-4">
            <div class="col-6">
                <span class="info-label">Accession Number</span>
                <span class="info-value text-orange dialog-accession-number">CS-001</span>
            </div>
            <div class="col-6">
                <span class="info-label">Category</span>
                <span class="info-value dialog-category">Computer Science</span>
            </div>
            <div class="col-6">
                <span class="info-label">ISBN</span>
                <span class="info-value dialog-isbn">978-0-123456-78-9</span>
            </div>
            <div class="col-6">
                <span class="info-label">Copies</span>
                <span class="info-value dialog-copies">5</span>
            </div>
        </div>

        <button class="btn btn-signin w-100">
            <i class="fas fa-sign-in-alt"></i> Sign In
        </button>
    </dialog>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>


<script>
    const dialog = document.getElementById('bookDialog');
    const openBtn = document.querySelectorAll('.book-card');
    const closeBtn = document.getElementById('closeDialogBtn');
    const urlParams = new URLSearchParams(window.location.search);
    const categoryId = urlParams.get('category');
    const status = urlParams.get('status')

    if (categoryId) {
        const selectElement = document.getElementById('categorySelect');

        if (selectElement) {
            selectElement.value = categoryId;
        }
    }

    if (status) {
        const selectElement = document.getElementById('statusSelect');

        if (selectElement) {
            selectElement.value = status;
        }
    }

    openBtn.forEach((item, index) => {
        item.addEventListener('click', () => {
            dialog.showModal();
            document.querySelector('.dialog-title').innerHTML = item.dataset.title;
            document.querySelector('.dialog-subtitle').innerHTML = item.dataset.author;
            document.querySelector('.dialog-accession-number').innerHTML = item.dataset.accessionNumber;
            document.querySelector('.dialog-category').innerHTML = item.dataset.category;
            document.querySelector('.dialog-isbn').innerHTML = item.dataset.isbn;
            document.querySelector('.dialog-copies').innerHTML = item.dataset.totalQuantity;
            document.querySelector('.book-image').src = item.dataset.image;
        });
    })

    closeBtn.addEventListener('click', () => {
        dialog.close();
    });

    dialog.addEventListener('click', (e) => {
        const dialogDimensions = dialog.getBoundingClientRect();
        if (
            e.clientX < dialogDimensions.left ||
            e.clientX > dialogDimensions.right ||
            e.clientY < dialogDimensions.top ||
            e.clientY > dialogDimensions.bottom
        ) {
            dialog.close();
        }
    });
</script>